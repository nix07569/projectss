<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fragment: OverviewCards.fragment.xml
  Purpose : Renders the KPI card grid for Overview pages (Group / CIB / WRB).
  Binding : Bound to the "cards" array of the active segment/view from mockData.
  Usage   : Fragment.load({ name: "finsight.fragment.OverviewCards", controller: oController })
              .then(function(oFrag){ oContainer.addItem(oFrag); });
-->
<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout">

  <layout:Grid
    id="overviewGrid"
    defaultSpan="XL4 L4 M6 S12"
    hSpacing="1"
    vSpacing="1"
    class="finsightCardGrid">

    <layout:content>

      <!--
        Each card is bound via aggregation binding in the controller:
        overviewGrid.bindAggregation("content", { path: "view>/cards", template: cardTemplate })
        The template below is instantiated per card item.
      -->

      <!-- NOTE: Static cards shown here as the fragment template.
           Controller replaces these with dynamic binding.
           This file serves as the visual definition & backup static render. -->

      <!-- ── CARD TEMPLATE (repeated per data item) ── -->
      <Panel
        id="kpiCardTemplate"
        class="finsightKPICard"
        backgroundDesign="Solid">
        <content>
          <VBox class="finsightKPICardInner">

            <!-- Card Title -->
            <Title text="{view>title}" level="H5" class="finsightCardTitle" />

            <!-- Main KPI row: Actual vs Prior -->
            <HBox alignItems="End" class="finsightKPIRow" justifyContent="SpaceBetween">
              <VBox>
                <Label text="Actual" class="finsightKPIMeta" />
                <Text text="{view>displayActual}" class="finsightKPIActual" />
              </VBox>
              <VBox>
                <Label text="Prior Year" class="finsightKPIMeta" />
                <Text text="{view>displayPrior}" class="finsightKPIPrior" />
              </VBox>
              <VBox>
                <Label text="Budget" class="finsightKPIMeta" />
                <Text text="{view>displayBudget}" class="finsightKPIBudget" />
              </VBox>
            </HBox>

            <!-- Variance badge -->
            <HBox alignItems="Center" class="finsightVarianceRow">
              <core:Icon
                src="{= ${view>varianceDir} === 'up' ? 'sap-icon://trend-up' : 'sap-icon://trend-down' }"
                class="{= ${view>varianceDir} === 'up' ? 'finsightVarUp' : 'finsightVarDown' }" />
              <Text
                text="{= Math.abs(${view>variance}) + '%' }"
                class="{= ${view>varianceDir} === 'up' ? 'finsightVarUpText' : 'finsightVarDownText' }" />
              <Label text=" vs PY" class="finsightVarLabel" />
            </HBox>

            <!-- Mini sparkline bar (CSS-driven) -->
            <HBox class="finsightSparkRow" alignItems="End">
              <core:HTML content="{view>sparkHtml}" />
            </HBox>

          </VBox>
        </content>
      </Panel>

    </layout:content>
  </layout:Grid>

</core:FragmentDefinition>
