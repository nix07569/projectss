<?xml version="1.0" encoding="UTF-8"?>
<!--
    Fragment : project1.view.fragments.overviewCards
    Purpose  : Outer FlexBox grid shell for the 12-card Overview layout.
               The controller fills cards programmatically into this FlexBox.
    Binding  : Controller calls Fragment.load() → appends to #cardContainer
-->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <FlexBox
        id="overviewGrid"
        wrap="Wrap"
        alignItems="Stretch"
        justifyContent="Start"
        class="fsOverviewGrid" />

</core:FragmentDefinition>
