<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    controllerName="project1.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page id="mainPage" showHeader="false" backgroundDesign="Solid">

                <!-- ══ CUSTOM HEADER BAR ══ -->
                <customHeader>
                    <Bar design="Header" class="fsTopBar">
                        <contentLeft>
                            <HBox alignItems="Center">
                                <Button
                                    icon="sap-icon://menu2"
                                    type="Transparent"
                                    press=".onMenuPress" />
                                <VBox justifyContent="Center" class="fsLogoBlock">
                                    <Label text="Aspire" class="fsLogoAspire" />
                                    <HBox alignItems="Baseline">
                                        <Text text="Fin"          class="fsLogoFin"  />
                                        <Text text="Sight"        class="fsLogoSight"/>
                                        <Text text=".Performance" class="fsLogoPerf" />
                                    </HBox>
                                </VBox>
                            </HBox>
                        </contentLeft>
                        <contentRight>
                            <Button icon="sap-icon://action-settings" type="Transparent" />
                            <Button icon="sap-icon://person-placeholder" type="Transparent" />
                        </contentRight>
                    </Bar>
                </customHeader>

                <!-- ══ PAGE CONTENT ══ -->
                <content>
                    <VBox class="fsPageRoot">

                        <!-- Dynamic title: "Group | Financials | Overview" -->
                        <HBox alignItems="Center" class="fsTitleBar">
                            <core:Icon src="sap-icon://filter" class="fsFilterIcon" />
                            <Title
                                id="pageTitle"
                                text="{state>/headerTitle}"
                                level="H1"
                                class="fsPageTitle" />
                        </HBox>

                        <!-- ══ NAV PANEL (right-aligned) ══ -->
                        <HBox justifyContent="End" class="fsNavPanel">
                            <VBox alignItems="End" class="fsNavControls">

                                <!-- ROW 1: Segment — Group | CIB | WRB -->
                                <HBox class="fsSegRow">
                                    <Button id="btnGroup"
                                        text="Group"
                                        press=".onSegmentPress"
                                        data:key="Group"
                                        class="fsSegBtn" />
                                    <Button id="btnCIB"
                                        text="CIB"
                                        press=".onSegmentPress"
                                        data:key="CIB"
                                        class="fsSegBtn" />
                                    <Button id="btnWRB"
                                        text="WRB"
                                        press=".onSegmentPress"
                                        data:key="WRB"
                                        class="fsSegBtn" />
                                </HBox>

                                <!-- ROW 2: View — Overview | Trends -->
                                <HBox class="fsViewRow">
                                    <Button id="btnOverview"
                                        text="Overview"
                                        press=".onViewPress"
                                        data:key="Overview"
                                        class="fsViewBtn" />
                                    <Button id="btnTrends"
                                        text="Trends"
                                        press=".onViewPress"
                                        data:key="Trends"
                                        class="fsViewBtn" />
                                </HBox>

                                <!-- ROW 3: Reporting Period + $m/$bn + RFX/CFX -->
                                <HBox alignItems="Center" class="fsTogglesRow">
                                    <Label text="Reporting Period :" class="fsRPLabel" />
                                    <Text  text="{mockData>/reportingPeriod}" class="fsRPValue" />

                                    <SegmentedButton
                                        id="unitToggle"
                                        selectedKey="m"
                                        selectionChange=".onUnitToggle"
                                        class="fsSegToggle">
                                        <items>
                                            <SegmentedButtonItem key="m"  text="$m"  />
                                            <SegmentedButtonItem key="bn" text="$bn" />
                                        </items>
                                    </SegmentedButton>

                                    <SegmentedButton
                                        id="fxToggle"
                                        selectedKey="RFX"
                                        selectionChange=".onFXToggle"
                                        class="fsSegToggle">
                                        <items>
                                            <SegmentedButtonItem key="RFX" text="RFX" />
                                            <SegmentedButtonItem key="CFX" text="CFX" />
                                        </items>
                                    </SegmentedButton>
                                </HBox>

                            </VBox>
                        </HBox>

                        <!-- Reset -->
                        <HBox class="fsResetRow">
                            <Link text="Reset" press=".onReset" class="fsResetLink" />
                        </HBox>

                        <!-- Divider -->
                        <HTML content="&lt;hr class='fsDivider'/&gt;" />

                        <!-- ══ CONTENT AREA — blank placeholder ══ -->
                        <VBox id="contentArea" class="fsContentArea" busyIndicatorDelay="0">
                            <VBox id="blankPlaceholder" class="fsBlankArea">
                                <core:Icon src="sap-icon://business-objects-experience" class="fsBlankIcon" />
                                <Title text="{state>/headerTitle}" level="H4" class="fsBlankTitle" />
                                <Text  text="Content for this section will appear here." class="fsBlankText" />
                            </VBox>
                        </VBox>

                    </VBox>
                </content>
            </Page>
        </pages>
    </App>

</mvc:View>
