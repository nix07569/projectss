{
  "_version": "1.58.0",
  "sap.app": {
    "id": "finsight",
    "type": "application",
    "title": "FinSight Performance",
    "description": "FinSight Financial Performance Dashboard",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "finsight.view.App",
      "type": "XML",
      "async": true,
      "id": "appView"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "mockData": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/mockData.json"
      }
    },
    "resources": {
      "css": [{ "uri": "css/style.css" }]
    }
  }
}
